# ============================================================
# GuardianFlow AI — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# AZURE CORE
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_RESOURCE_GROUP=guardianflow-rg
AZURE_REGION=southeastasia
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-service-principal-secret

# DATABASE
DATABASE_URL=postgresql+asyncpg://guardianflow:SECRET@guardianflow.postgres.database.azure.com:5432/guardianflow?ssl=require
DATABASE_URL_SYNC=postgresql://guardianflow:SECRET@guardianflow.postgres.database.azure.com:5432/guardianflow?sslmode=require
REDIS_URL=rediss://guardianflow.redis.cache.windows.net:6380?password=SECRET&ssl=True
COSMOS_ENDPOINT=https://guardianflow.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DB=guardianflow-graph
COSMOS_GRAPH=fraud-graph

# MONITORING
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://southeastasia-0.in.applicationinsights.azure.com/
APPINSIGHTS_INSTRUMENTATIONKEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://southeastasia-0.in.applicationinsights.azure.com/

# AZURE SERVICES
AZURE_KEYVAULT_URL=https://guardianflow-kv.vault.azure.net/
AZURE_EVENTHUB_CONN_STR=Endpoint=sb://guardianflow-eh.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=SECRET
AZURE_EVENTHUB_NAME=transactions
AZURE_ML_WORKSPACE=guardianflow-ml
AZURE_ACR_LOGIN_SERVER=guardianflowacr.azurecr.io

# AZURE MONITOR WORKBOOK
NEXT_PUBLIC_MONITOR_WORKBOOK_URL=https://portal.azure.com/#view/Microsoft_Azure_Monitoring/...

# AUTH
JWT_SECRET=fetched-from-keyvault-at-startup
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# APP CONFIG
CORS_ORIGINS=https://guardianflow.azurestaticapps.net,http://localhost:3000
RISK_THRESHOLD_LOW=30
RISK_THRESHOLD_HIGH=70
WEBHOOK_TIMEOUT_SECONDS=5
RATE_LIMIT_PER_MINUTE=100

# FRONTEND
NEXT_PUBLIC_API_URL=https://guardianflow-api.azurecontainerapps.io
NEXT_PUBLIC_WS_URL=wss://guardianflow-api.azurecontainerapps.io/ws/transactions

# LOCAL DEV OVERRIDES (uncomment for local development)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/guardianflow
# REDIS_URL=redis://localhost:6379
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/transactions
